# Ollama model to use for summarization, mind maps, and translation
# Default: gemma4:e4b (must be pulled first: ollama pull gemma4:e4b)
# gemma3:4b runs on this laptop; gemma4:e4b is for the S24 Ultra (Android)
OLLAMA_MODEL=gemma3:4b

# Ollama server URL (default: local)
OLLAMA_BASE_URL=http://localhost:11434

# Optional: default output directory for exports
EXPORT_DIR=~/notetaker-exports

# Optional: Google Drive integration
# Download OAuth credentials JSON from Google Cloud Console
GDRIVE_CREDENTIALS_FILE=credentials.json
GDRIVE_TOKEN_FILE=token.json
